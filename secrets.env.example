# =============================================================================
# Secrets (sensitive values only — never commit the real secrets.env)
# =============================================================================

# --- Wallet (required) ---
wallet_password=your_secure_password

# --- RPC Endpoints (required for production) ---
# Include API keys in URLs if needed (e.g. Alchemy, Infura)
gnosis_rpc=https://rpc.gnosischain.com,https://rpc.gnosis.gateway.fm
ethereum_rpc=https://ethereum-rpc.publicnode.com
base_rpc=https://mainnet.base.org
polygon_rpc=https://polygon-rpc.com
optimism_rpc=https://mainnet.optimism.io
arbitrum_rpc=https://arb1.arbitrum.io/rpc
celo_rpc=https://forno.celo.org

# --- Telegram bot (optional — enables remote control) ---
# Get a token from @BotFather on Telegram
# telegram_token=
# telegram_chat_id=

# --- External LLM API keys (optional, for specific tools) ---
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# --- Health monitor URL (optional, e.g. Uptime Kuma push URL) ---
# health_url=
